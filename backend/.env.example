OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://genailab.tcs.in
OPENAI_MODEL=azure_ai/genailab-maas-DeepSeek-V3-0324
OPENAI_VERIFY_SSL=false
OPENAI_TIMEOUT_SECONDS=60
RAG_VECTOR_STORE_PATH=backend/data/rag/qdrant
RAG_COLLECTION_NAME=nutrition_knowledge
RAG_EMBEDDING_MODEL=azure/genailab-maas-text-embedding-3-large
RAG_EMBEDDING_DIMENSIONS=3072
RAG_CANDIDATE_K=24
RAG_RERANK_TOP_N=12
RAG_ENABLE_HYBRID=true
RAG_ENABLE_RERANK=true
RAG_DENSE_WEIGHT=0.62
RAG_LEXICAL_WEIGHT=0.38
RAG_INDEXING_BATCH_SIZE=24
RAG_ALLOW_LOCAL_EMBEDDING_FALLBACK=true
